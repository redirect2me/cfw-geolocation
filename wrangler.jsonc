{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cfw-geolocation",
  "main": "./src/worker.ts",
  "compatibility_date": "2026-06-19",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./public", // Serve static files
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
